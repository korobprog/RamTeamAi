{
  "name": "RamTeamAi-desktop",
  "private": true,
  "version": "0.1.10",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "powershell -ExecutionPolicy Bypass -File scripts\\tauri-dev.ps1",
    "check": "tsc --noEmit",
    "check:test": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri:build": "tauri build --config src-tauri/tauri.release-no-updater.json",
    "release:windows": "tauri build --bundles nsis --config src-tauri/tauri.release-no-updater.json",
    "release:mac": "tauri build --bundles dmg --config src-tauri/tauri.release-no-updater.json",
    "version:set": "powershell -ExecutionPolicy Bypass -File scripts\\set-version.ps1",
    "updater:key": "powershell -ExecutionPolicy Bypass -File scripts\\setup-updater-key.ps1",
    "dev:logs": "powershell -ExecutionPolicy Bypass -File scripts\\dev-with-logs.ps1"
  },
  "dependencies": {
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/api": "latest",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "latest",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.15.0",
    "lucide-react": "^1.20.0",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "zustand": "latest"
  },
  "devDependencies": {
    "@tauri-apps/cli": "latest",
    "@types/node": "^25.9.3",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "latest",
    "typescript": "latest",
    "vite": "latest",
    "vitest": "^4.1.9"
  }
}
