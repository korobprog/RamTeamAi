# GitHub OAuth App
# Create an OAuth App in GitHub Developer settings and enable Device Flow.
VITE_GITHUB_CLIENT_ID=

# Firebase Web App config
# These values are safe to keep in a client app; protect data with Firebase Auth + Firestore Rules.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=

