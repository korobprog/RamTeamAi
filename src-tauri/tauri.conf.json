{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RamTeamAi",
  "version": "0.1.8",
  "identifier": "dev.RamTeamAi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev -- --host 127.0.0.1 --port 1420 --strictPort",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "RamTeamAi",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 620,
        "maximized": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "********************************************************************************MVhZOFBXWWNZVVg2bnNCdzhmMmdxWjhTWElNcGE3bjlhWmd4U1R2OWVpTHFpUkhHOUg4ZEQK",
      "endpoints": [
        "https://github.com/korobprog/RamTeamAi/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}

